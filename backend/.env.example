# Copy to backend/.env for local development.

NODE_ENV=development
PORT=3000

# Matches the docker-compose Postgres service.
DATABASE_URL=postgresql://rounds:rounds@localhost:5432/rounds?schema=public

# Supabase JWT verification (consumed from Phase 3 onward; optional until then).
# SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
# SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
