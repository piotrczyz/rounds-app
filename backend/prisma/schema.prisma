// Rounds data model.
// Phase 1 establishes the datasource + generator and the migration workflow.
// The group-ready, sync-ready models (User, Group, Membership, Round, Completion)
// land in Phase 2.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
